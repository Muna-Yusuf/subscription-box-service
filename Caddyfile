{
    admin off
}

localhost {
    root * /usr/share/caddy
    file_server
    
    # Reverse proxy to API
    reverse_proxy /api/* http://localhost:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
    
    # Logging
    log {
        output stdout
        format json
    }
}